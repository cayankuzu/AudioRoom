{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "depo/henry_the_lee/**/src/**/*.ts",
    "depo/hayko_cepkin/**/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "depo/redd/mukemmel_bosluk/node_modules",
    "depo/redd/mukemmel_bosluk/src"
  ]
}
